# Application
APP_NAME=TG Monitor Platform
APP_HOST=127.0.0.1
APP_PORT=8098
APP_DEBUG=false

# MySQL Database
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=change_me
DATABASE_NAME=tg_monitor

# Telegram Session
TELEGRAM_SESSION_PATH=./data/telethon.session
TELEGRAM_SESSION_MODE=manual
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Telegram Desktop Import (disabled by default, see README)
TELEGRAM_TDATA_PATH=
TELEGRAM_DESKTOP_IMPORT_ENABLED=false
TELEGRAM_DESKTOP_IMPORT_MODE=create_new

# Collection
TELEGRAM_BACKGROUND_COLLECTION_ENABLED=false
TELEGRAM_LIVE_LISTENER_ENABLED=false
TELEGRAM_DOWNLOAD_MEDIA_ENABLED=false
TELEGRAM_FETCH_USER_ABOUT_ENABLED=false
TELEGRAM_JOIN_QUEUE_ENABLED=true
TELEGRAM_JOIN_INTERVAL_MINUTES=10

# Sync Tuning
SYNC_BATCH_SIZE=200
SYNC_LOOKBACK_MESSAGES=1000
SYNC_INTERVAL_MINUTES=5

# AI Summary
AI_SUMMARY_BATCH_SIZE=1000
AI_SUMMARY_RUNNING_TIMEOUT_MINUTES=30

# Analysis
ANALYSIS_TOP_KEYWORDS=30

# Storage
MEDIA_STORAGE_PATH=./data/media

# Text Analysis
STOPWORDS_EXTRA=

# Auth — change these before deploying to production!
AUTH_PASSWORD=change-me
API_SK=change-me-api-sk
